{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "verbatimModuleSyntax": false,
    "erasableSyntaxOnly": false,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0"
  }
}
